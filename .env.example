# ---- Aivo environment variables ----
# Copy to `.env` and fill in. NEVER commit `.env`.

# --- Shopify app (from Partner Dashboard > App > Client credentials) ---
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# Comma-separated. Must match [access_scopes] in shopify.app.toml.
SCOPES=read_products,write_products
# Public URL of the deployed app (Railway URL or tunnel URL in dev).
SHOPIFY_APP_URL=
# Optional: only set when testing against a custom shop domain.
# SHOP_CUSTOM_DOMAIN=

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/aivo

# --- Redis / job queue (BullMQ) — used from Phase 4 onward ---
REDIS_URL=redis://localhost:6379

# --- LLM providers (added per phase; keys not required until then) ---
# Phase 3 (enrichment):
ANTHROPIC_API_KEY=
# Phase 4 (citation tracking):
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# --- Observability (optional; Sentry skipped for v1) ---
# SENTRY_DSN=
