{%- comment -%}
  Cited — JSON-LD structured data (app embed block, injected in <head>).
  Zero render-blocking weight: emits only inert <script type="application/ld+json">.
  Repairs/adds: Organization (all pages), Product + Offer + AggregateRating
  (product pages), and FAQPage from the "cited.faq" metafield written by the
  AI enrichment flow. Validate with Google's Rich Results Test (QA-6).
{%- endcomment -%}

{%- if block.settings.enabled -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "url": {{ shop.url | json }}
    {%- if shop.brand.logo -%}
    , "logo": {{ shop.brand.logo | image_url: width: 512 | prepend: "https:" | json }}
    {%- endif -%}
  }
  </script>

  {%- if template contains 'product' and product -%}
    {%- assign v = product.selected_or_first_available_variant -%}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Product",
      "name": {{ product.title | json }},
      "description": {{ product.description | strip_html | truncate: 500 | json }},
      "url": {{ product.url | prepend: shop.url | json }},
      {%- if product.featured_image -%}
      "image": [
        {%- for image in product.images limit: 5 -%}
          {{ image | image_url: width: 1200 | prepend: "https:" | json }}{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ],
      {%- endif -%}
      {%- if product.vendor != blank -%}
      "brand": { "@type": "Brand", "name": {{ product.vendor | json }} },
      {%- endif -%}
      {%- if v.sku != blank -%}
      "sku": {{ v.sku | json }},
      {%- endif -%}
      {%- if v.barcode != blank -%}
      "gtin": {{ v.barcode | json }},
      {%- endif -%}
      {%- assign rating = product.metafields.reviews.rating -%}
      {%- assign rating_count = product.metafields.reviews.rating_count -%}
      {%- if rating and rating_count and rating_count.value > 0 -%}
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": {{ rating.value.rating | default: rating.value | json }},
        "reviewCount": {{ rating_count.value | json }}
      },
      {%- endif -%}
      "offers": {
        "@type": "Offer",
        "price": "{{ v.price | divided_by: 100.00 }}",
        "priceCurrency": {{ cart.currency.iso_code | json }},
        "availability": "{%- if v.available -%}https://schema.org/InStock{%- else -%}https://schema.org/OutOfStock{%- endif -%}",
        "url": {{ product.url | prepend: shop.url | json }}
      }
    }
    </script>

    {%- assign faq = product.metafields.cited.faq.value -%}
    {%- if faq and faq.size > 0 -%}
      <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {%- for item in faq -%}
          {
            "@type": "Question",
            "name": {{ item.question | json }},
            "acceptedAnswer": { "@type": "Answer", "text": {{ item.answer | json }} }
          }{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        ]
      }
      </script>
    {%- endif -%}
  {%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "Cited SEO Schema",
  "target": "head",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Output AI-search structured data (JSON-LD)",
      "default": true
    }
  ]
}
{% endschema %}
